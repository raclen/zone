---
import { FEATURES } from "../data/features";

// 图标 SVG（统一 24x24 描边风格），按 feature.icon 取用。
const icons: Record<string, string> = {
  desktop:
    '<rect x="2" y="3.5" width="20" height="14" rx="2"/><path d="M8 20.5h8M12 17.5v3"/>',
  puzzle:
    '<path d="M9 2.5v5M15 2.5v5"/><path d="M6 7.5h12v3.2a6 6 0 0 1-12 0V7.5Z"/><path d="M12 17v4.5"/>',
  lyrics:
    '<path d="M9 18V5l11-2v12"/><circle cx="6" cy="18" r="3"/><circle cx="17" cy="15" r="3"/>',
  folder:
    '<path d="M3 7a2 2 0 0 1 2-2h3.6a2 2 0 0 1 1.4.6L11.4 7H19a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  palette:
    '<path d="M12 2.5a9.5 9.5 0 1 0 0 19c.83 0 1.5-.67 1.5-1.5 0-.4-.16-.76-.42-1.03a1.5 1.5 0 0 1 1.06-2.55H16a5 5 0 0 0 5-5C21 6.7 16.97 2.5 12 2.5Z"/><circle cx="7.5" cy="10.5" r="1"/><circle cx="12" cy="7.5" r="1"/><circle cx="16.5" cy="10.5" r="1"/>',
  download:
    '<path d="M12 3.5v11m0 0 4-4m-4 4-4-4"/><path d="M4 16.5v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/>',
  shield:
    '<path d="M12 2.5 4.5 5.5v5.5c0 4.6 3.2 7.9 7.5 9.5 4.3-1.6 7.5-4.9 7.5-9.5V5.5L12 2.5Z"/><path d="m9 11.5 2 2 4-4"/>',
};
---

<section class="section" id="features">
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">核心功能</span>
      <h2 class="section-title">一个播放器，<span class="gradient-text">该有的都有</span></h2>
      <p class="section-desc">
        本地与在线兼顾，插件、歌词、主题、下载全面可定制 —— 纯净、自由、属于你自己的音乐空间。
      </p>
    </div>

    <div class="feature-grid">
      {
        FEATURES.map((f) => (
          <article class="feature-card glass reveal">
            <div class="feature-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[f.icon]}
              />
            </div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .feature-card {
    padding: 26px 22px;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--glow-soft);
  }
  .feature-icon {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 13px;
    margin-bottom: 18px;
    color: var(--brand-bright);
    background: linear-gradient(135deg, rgba(32, 167, 255, 0.16), rgba(139, 92, 246, 0.16));
    border: 1px solid rgba(32, 167, 255, 0.22);
  }
  .feature-icon svg {
    width: 24px;
    height: 24px;
  }
  .feature-card h3 {
    font-size: 1.12rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .feature-card p {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
