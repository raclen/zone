---
interface Props {
  post: any;
}

const { post } = Astro.props;
const { slug, data } = post;
const { title, description, pubDate, tags, issueNumber } = data;

// 格式化日期
const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '-');

// 判断是否置顶
const isPinned = issueNumber && issueNumber <= 3; // 前3个 Issue 视为置顶
---

<a href={`/blog/${slug}`} class="post-card">
  <div class="post-card__header">
    <h2 class="post-card__title">
      {isPinned && (
        <span class="post-card__pinned">
          <svg class="post-card__pinned-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.76 3.76a.75.75 0 1 1-1.06 1.06L10.328 3.46a.75.75 0 0 1 1.06-1.06l1.372 1.36zm4.45 1.44a.75.75 0 0 0-1.06 0l-1.45 1.45a.75.75 0 0 0 1.06 1.06l1.45-1.45a.75.75 0 0 0 0-1.06zm-1.06 4.95a.75.75 0 0 0 0-1.06l-1.45-1.45a.75.75 0 0 0-1.06 1.06l1.45 1.45a.75.75 0 0 0 1.06 0zm-1.06 1.06a.75.75 0 0 0-1.06 0l-1.45 1.45a.75.75 0 0 0 1.06 1.06l1.45-1.45a.75.75 0 0 0 0-1.06z"/>
          </svg>
          HOT
        </span>
      )}
      {title}
    </h2>
  </div>

  {description && (
    <p class="post-card__excerpt">{description}</p>
  )}

  <div class="post-card__footer">
    <div class="post-card__meta">
      <svg class="post-card__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <span class="post-card__date">{formattedDate}</span>
    </div>

    {tags && tags.length > 0 && (
      <div class="post-card__tags">
        {tags.slice(0, 3).map((tag: string) => (
          <span class="post-card__tag">
            <svg class="post-card__tag-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
              <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .post-card {
    display: block;
    background-color: var(--color-bg);
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  }

  .post-card:hover {
    border-color: var(--color-brand);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .post-card:hover .post-card__title {
    color: var(--color-brand);
  }

  .post-card:hover .post-card__excerpt {
    color: var(--color-text-1);
  }

  .post-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .post-card__title {
    flex: 1;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text-1);
    margin: 0;
    transition: color 0.2s ease;
  }

  .post-card__pinned {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.5rem;
    margin-right: 0.5rem;
    background-color: var(--color-brand-soft);
    color: var(--color-brand);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.4;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card__pinned-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .post-card__excerpt {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-2);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s ease;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-3);
    font-size: 0.875rem;
  }

  .post-card__icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .post-card__date {
    font-family: var(--font-family-mono);
  }

  .post-card__tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    background-color: var(--color-bg-alt);
    color: var(--color-text-2);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    border-radius: var(--radius);
    transition: all 0.2s ease;
  }

  .post-card__tag:hover {
    background-color: var(--color-brand-soft);
    color: var(--color-brand);
  }

  .post-card__tag-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  @media (max-width: 768px) {
    .post-card {
      padding: 1rem;
    }

    .post-card__title {
      font-size: 1.125rem;
    }

    .post-card__excerpt {
      font-size: 0.875rem;
      -webkit-line-clamp: 3;
    }
  }
</style>
