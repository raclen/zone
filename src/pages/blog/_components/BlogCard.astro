---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

// 格式化日期
const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="blog-card">
  <a href={`/blog/${post.slug}`}>
    <div class="card-content">
      <time class="card-date" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>

      <h2 class="card-title">{title}</h2>

      {description && <p class="card-desc">{description}</p>}

      {tags.length > 0 && (
        <div class="card-tags">
          {tags.map((tag) => (
            <span class="tag-badge">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <div class="card-arrow">→</div>
  </a>
</article>

<style>
  .blog-card {
    background: var(--canvas);
    border: 1px solid var(--hairline-soft);
    border-radius: 12px;
    transition: all 0.25s ease;
    overflow: hidden;
    height: 100%;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--hairline);
  }

  .blog-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .card-content {
    flex: 1;
  }

  .card-date {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 12px;
    display: block;
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 12px;
    color: var(--ink);
  }

  .card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.7;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-badge {
    font-size: 0.75rem;
    padding: 4px 10px;
    border-radius: 4px;
    background: var(--surface-soft);
    font-weight: 500;
  }

  .card-arrow {
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 1.5rem;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.25s ease;
  }

  .blog-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .blog-card a {
      padding: 20px;
    }

    .card-title {
      font-size: 1.15rem;
    }

    .card-arrow {
      display: none;
    }
  }
</style>
