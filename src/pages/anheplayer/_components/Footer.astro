---
import { GITHUB_REPO_URL, UPSTREAM_URL } from "@/data/platforms";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/logo.svg" alt="" width="40" height="40" />
        <span class="footer-name">AnhePlayer</span>
        <p class="footer-desc">支持洛雪插件 · 无广告的免费音乐播放器</p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h4>项目</h4>
          <a href={GITHUB_REPO_URL} target="_blank" rel="noopener">GitHub 仓库</a>
          <a href={`${GITHUB_REPO_URL}/releases`} target="_blank" rel="noopener">历史版本</a>
          <a href={`${GITHUB_REPO_URL}/issues`} target="_blank" rel="noopener">反馈问题</a>
        </div>
        <div class="footer-col">
          <h4>开源</h4>
          <a href={`${GITHUB_REPO_URL}/blob/master/LICENSE`} target="_blank" rel="noopener"
            >AGPL-3.0 许可证</a
          >
          <a href={UPSTREAM_URL} target="_blank" rel="noopener">基于 MusicFreeDesktop</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} AnhePlayer. 采用 AGPL-3.0 协议开源。</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: 64px 32px;
    background: var(--surface-soft);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-brand img {
    border-radius: 10px;
    margin-bottom: 12px;
  }

  .footer-name {
    display: block;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .footer-desc {
    color: var(--ink);
    opacity: 0.6;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    gap: 56px;
  }

  .footer-col h4 {
    font-size: 0.88rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 14px;
    color: var(--ink);
    opacity: 0.5;
  }

  .footer-col a {
    display: block;
    font-size: 0.95rem;
    color: var(--ink);
    opacity: 0.7;
    margin-bottom: 10px;
    transition: opacity 0.2s ease;
  }

  .footer-col a:hover {
    opacity: 1;
  }

  .footer-bottom {
    padding-top: 32px;
    border-top: 1px solid var(--hairline);
    text-align: center;
  }

  .footer-bottom p {
    color: var(--ink);
    opacity: 0.5;
    font-size: 0.88rem;
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
      gap: 36px;
    }
    .footer-links {
      gap: 36px;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      flex-direction: column;
      gap: 24px;
    }
  }
</style>
