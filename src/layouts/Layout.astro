---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AnhePlayer · 支持洛雪插件的免费音乐播放器",
  description = "AnhePlayer 是一款跨平台、可定制、支持插件扩展的桌面音乐播放器。支持洛雪插件、无广告、不上传个人数据，覆盖 Windows、macOS 与 Linux。",
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
const ogImage = Astro.site
  ? new URL("/og-image.png", Astro.site).href
  : "/og-image.png";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#070b16" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="AnhePlayer" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot />

    <!-- 滚动淡入：为 .reveal 元素添加 is-visible -->
    <script>
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
